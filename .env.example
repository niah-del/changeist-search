# Copy this file to .env.local for local development
# Never commit .env.local to git

# Supabase — Settings → API in your Supabase dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Serper.dev — real Google results (2,500 free queries on signup)
# Sign up at https://serper.dev
SERPER_API_KEY=your-serper-api-key

# Admin password for /api/listings endpoint
# Generate with: openssl rand -hex 32
ADMIN_SECRET=replace-with-a-long-random-string

# Anthropic — powers the chat assistant
# Get your key at https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Embed key used by changeist.org itself (no DB row needed)
# Use this value in your own site's <script> tag
INTERNAL_EMBED_KEY=changeist-internal
